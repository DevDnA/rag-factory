    "query": "string — 한국어 자연 질문",
    "expected": "string (선택, lookup만) — 정답 토큰. substring 매칭 평가에 사용",
    "difficulty": "easy | medium | hard",
    "multi_hop": "bool (선택) — true이면 한 청크에 답이 없고 2개 이상 섹션 연결 필요"
